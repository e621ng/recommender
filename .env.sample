# Copy this file to .env and adjust values for your environment.
# All variables use the RECOMMENDER_ prefix and can also be passed as environment variables.

# PostgreSQL connection string for the e621ng database.
RECOMMENDER_DB_DSN=postgresql://postgres:postgres@localhost:5432/e621

# Directory where versioned model artifacts are stored.
# Mount a persistent volume here in production.
RECOMMENDER_MODEL_DIR=/models

# API bind address and worker count.
RECOMMENDER_API_HOST=0.0.0.0
RECOMMENDER_API_PORT=8000
RECOMMENDER_API_WORKERS=1

# Blend weights for the hybrid vector (collaborative vs. tag components).
# Final vector is L2-normalized after blending.
RECOMMENDER_W_CF=1.0
RECOMMENDER_W_TAG=0.3

# Embedding dimension shared by collaborative and tag embeddings.
RECOMMENDER_EMBEDDING_DIM=64

# Top tags stored per post (used for /similar?explain=true).
RECOMMENDER_N_TOP_TAGS=50

# Tags to exclude from the model regardless of category (JSON array).
# Useful for utility/administrative tags that carry no semantic signal.
RECOMMENDER_EXCLUDED_TAGS=["translated","partially_translated","translation_check","translation_request","avoid_posting","conditional_dnp","epilepsy_warning","sound_warning","unknown_artist","anonymous_artist","third-party_edit"]

# Max number of shared tags returned in an explanation response.
RECOMMENDER_M_SHARED_TAGS=6

# SGD learning rate and L2 regularization for incremental embedding updates.
RECOMMENDER_SGD_LR=0.01
RECOMMENDER_SGD_REG=0.001

# Rows fetched per database query during updater runs.
RECOMMENDER_EVENTS_BATCH_SIZE=50000
RECOMMENDER_POSTS_BATCH_SIZE=10000

# hnswlib index parameters.
# M: graph connectivity (higher = better recall, more memory).
# EF_CONSTRUCTION: build-time search width (higher = better quality, slower build).
# EF_SEARCH: query-time search width (higher = better recall, slower queries).
RECOMMENDER_HNSW_M=32
RECOMMENDER_HNSW_EF_CONSTRUCTION=200
RECOMMENDER_HNSW_EF_SEARCH=100

# Log level (DEBUG, INFO, WARNING, ERROR) and format.
# Set LOG_JSON=false for human-readable output during local development.
RECOMMENDER_LOG_LEVEL=INFO
RECOMMENDER_LOG_JSON=true

# Number of old model versions to retain on disk before pruning.
RECOMMENDER_KEEP_VERSIONS=3
